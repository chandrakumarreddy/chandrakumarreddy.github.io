<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {%- set isPost = "posts" in (tags or []) %}
  {%- set pageUrl = site.url + page.url %}
  {%- set metaDesc = description or site.description %}
  {%- set latestPost = collections.posts | first %}
  {%- set ogImage = (site.url + "/assets/" + page.fileSlug + "/hero.png") if isPost else (site.url + "/assets/" + (latestPost.fileSlug if latestPost else "") + "/hero.png") %}
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ metaDesc }}">
  <meta name="author" content="{{ site.title }}">
  <meta name="robots" content="index, follow, max-image-preview:large">
  <link rel="canonical" href="{{ pageUrl }}">
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 40 40'%3E%3Crect width='40' height='40' rx='10' fill='%23D97757'/%3E%3Cg fill='none' stroke='white' stroke-width='3.4' stroke-linecap='round' stroke-linejoin='round'%3E%3Cpath d='M27 13.4a9.3 9.3 0 1 0 0 13.2'/%3E%3Cpath d='M18.8 13.8v12.4'/%3E%3Cpath d='M18.8 20l7-6.2M18.8 20l7 6.2'/%3E%3C/g%3E%3C/svg%3E">
  <link rel="alternate" type="application/atom+xml" title="{{ site.title }}" href="{{ site.url }}/feed.xml">

  <meta property="og:site_name" content="{{ site.title }}">
  <meta property="og:locale" content="en_US">
  <meta property="og:title" content="{{ title or site.title }}">
  <meta property="og:description" content="{{ metaDesc }}">
  <meta property="og:type" content="{{ 'article' if isPost else 'website' }}">
  <meta property="og:url" content="{{ pageUrl }}">
  <meta property="og:image" content="{{ ogImage }}">
  {%- if isPost %}
  <meta property="article:published_time" content="{{ page.date | htmlDateString }}">
  <meta property="article:author" content="{{ site.title }}">
  {%- endif %}

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@chandra_penugon">
  <meta name="twitter:creator" content="@chandra_penugon">
  <meta name="twitter:title" content="{{ title or site.title }}">
  <meta name="twitter:description" content="{{ metaDesc }}">
  <meta name="twitter:image" content="{{ ogImage }}">

  {%- if isPost %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": {{ title | dump | safe }},
    "description": {{ metaDesc | dump | safe }},
    "image": "{{ ogImage }}",
    "datePublished": "{{ page.date | htmlDateString }}",
    "dateModified": "{{ page.date | htmlDateString }}",
    "author": {
      "@type": "Person",
      "name": "{{ site.title }}",
      "url": "{{ site.url }}/about/"
    },
    "publisher": {
      "@type": "Person",
      "name": "{{ site.title }}",
      "url": "{{ site.url }}"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "{{ pageUrl }}"
    }
  }
  </script>
  {%- else %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ site.title }}",
    "url": "{{ site.url }}",
    "description": {{ site.description | dump | safe }},
    "author": {
      "@type": "Person",
      "name": "{{ site.title }}",
      "url": "{{ site.url }}/about/",
      "sameAs": [
        "https://github.com/chandrakumarreddy",
        "https://www.linkedin.com/in/chandra-penugonda/",
        "https://x.com/chandra_penugon"
      ]
    }
  }
  </script>
  {%- endif %}

  {%- for f in fonts.preload %}
  <link rel="preload" href="/fonts/{{ f.file }}" as="font" type="font/woff2" crossorigin>
  {%- endfor %}

  <script>
    (function () {
      try {
        var t = localStorage.getItem("theme") || "dark";
        document.documentElement.setAttribute("data-theme", t);
      } catch (e) { document.documentElement.setAttribute("data-theme", "dark"); }
    })();
  </script>

  <style>
    /* Self-hosted @font-face rules (generated by `npm run fonts`). */
    {{ fonts.css | safe }}
    /* Metrics-matched fallback for Google Sans Flex: renders Arial sized to
       occupy the same box as the web font, so the swap-in causes no layout
       shift (no flicker). Override values derived from the font's own metrics
       (unitsPerEm 2000, ascent 1932, descent -572, xAvgCharWidth 1137)
       relative to Arial (em 2048, xAvgCharWidth 904). */
    @font-face {
      font-family: "Google Sans Flex Fallback";
      src: local("Arial");
      size-adjust: 128.79%;
      ascent-override: 75.01%;
      descent-override: 22.21%;
      line-gap-override: 0%;
    }
    :root {
      --bg:#FAF9F5; --bg-tint:#F0EEE6; --surface:#FFFFFF;
      --ink:#1F1E1D; --ink-soft:#3D3C38; --muted:#73726C; --hair:#E6E2D8;
      --accent:#D97757; --accent-2:#D97757; --accent-ink:#BD5D3A;
      --pill-bg:#F3E9E2; --code-bg:#F2EFE7;
      --shadow:0 1px 2px rgba(30,26,20,.05), 0 8px 24px rgba(30,26,20,.06);
      --shadow-sm:0 1px 2px rgba(30,26,20,.05), 0 4px 14px rgba(30,26,20,.04);
      --display:"Google Sans Flex","Google Sans Flex Fallback",system-ui,sans-serif;
      --body:"Google Sans Flex","Google Sans Flex Fallback",system-ui,sans-serif;
      --serif:"Google Sans Flex","Google Sans Flex Fallback",system-ui,sans-serif;
      --mono:"JetBrains Mono",ui-monospace,"SF Mono",Menlo,monospace;
      --measure:42rem; --max:1120px; --gutter:clamp(1.25rem,5vw,3rem);
    }
    [data-theme="dark"] {
      --bg:#262624; --bg-tint:#1F1E1D; --surface:#30302E;
      --ink:#F5F4EE; --ink-soft:#D6D4CC; --muted:#9C9A92; --hair:#3D3C38;
      --accent:#D97757; --accent-2:#E08868; --accent-ink:#E5926E;
      --pill-bg:#3A2E27; --code-bg:#1F1E1D;
      --shadow:0 1px 2px rgba(0,0,0,.3), 0 12px 32px rgba(0,0,0,.4);
      --shadow-sm:0 1px 2px rgba(0,0,0,.3), 0 6px 18px rgba(0,0,0,.32);
    }
    * { box-sizing:border-box; }
    html { -webkit-text-size-adjust:100%; scroll-behavior:smooth; }
    body { margin:0; background:var(--bg); color:var(--ink); font-family:var(--body);
      font-size:17px; line-height:1.65; -webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility;
      transition:background-color .25s ease, color .25s ease; }
    a { color:var(--accent-ink); }
    .wrap { width:100%; margin:0 auto; padding-inline:max(var(--gutter), calc((100% - var(--max)) / 2)); }
    .narrow { max-width:720px; }

    .nav { position:sticky; top:0; z-index:30; backdrop-filter:saturate(140%) blur(10px);
      background:color-mix(in srgb, var(--bg) 82%, transparent); border-bottom:1px solid var(--hair); }
    .nav .wrap { display:flex; align-items:center; justify-content:space-between; height:64px; }
    .brand { display:flex; align-items:center; gap:.6rem; text-decoration:none; color:var(--ink); font-family:var(--display); font-weight:700; font-size:1.02rem; }
    .brand .mark { width:36px; height:36px; display:block; flex:none; border-radius:10px; box-shadow:var(--shadow-sm); }
    .nav-links { display:flex; align-items:center; gap:1.4rem; }
    .nav-links a { color:var(--ink-soft); text-decoration:none; font-size:.94rem; font-weight:500; }
    .nav-links a:hover, .nav-links a[aria-current="page"] { color:var(--accent-ink); }
    .icon-btn { display:grid; place-items:center; width:36px; height:36px; border-radius:9px; border:1px solid var(--hair); background:var(--surface); color:var(--ink-soft); cursor:pointer; }
    .icon-btn:hover { color:var(--accent-ink); border-color:var(--accent); }
    .icon-btn svg { width:18px; height:18px; }
    [data-theme="light"] .moon { display:none; }
    [data-theme="dark"] .sun { display:none; }
    @media (max-width:600px){ .nav-links a:not(.rss){ display:none; } }

    .hero { position:relative; overflow:hidden; border-bottom:1px solid var(--hair); }
    .hero::before { content:""; position:absolute; inset:0; background:radial-gradient(60% 80% at 88% 0%, var(--bg-tint), transparent 70%); pointer-events:none; }
    .hero .wrap { position:relative; display:grid; grid-template-columns:1.1fr .9fr; gap:clamp(2rem,5vw,4rem); align-items:center; padding-block:clamp(2.75rem,7vw,5rem); }
    .eyebrow { font-family:var(--mono); font-size:.74rem; letter-spacing:.08em; text-transform:uppercase; color:var(--accent-ink); margin:0 0 1.1rem; }
    .hero h1 { font-family:var(--display); font-weight:700; letter-spacing:-0.02em; line-height:1.1; font-size:clamp(2.1rem,4.6vw,3.1rem); margin:0 0 1.1rem; }
    .hero h1 .grad { color:var(--accent-ink); }
    .hero .lede { color:var(--ink-soft); font-size:1.12rem; line-height:1.6; max-width:54ch; margin:0 0 1.5rem; }
    .topics { list-style:none; display:flex; flex-wrap:wrap; gap:.5rem; margin:0 0 1.8rem; padding:0; }
    .topics li { font-family:var(--body); font-size:.82rem; font-weight:500; color:var(--ink-soft); background:var(--surface); border:1px solid var(--hair); border-radius:999px; padding:.35rem .8rem; }
    .cta-row { display:flex; flex-wrap:wrap; gap:.8rem; }
    .btn { display:inline-flex; align-items:center; gap:.5rem; padding:.8rem 1.25rem; border-radius:11px; font-family:var(--body); font-weight:600; font-size:.96rem; text-decoration:none; cursor:pointer; border:1px solid transparent; transition:transform .12s ease, box-shadow .2s ease; }
    .btn svg { width:16px; height:16px; }
    .btn-primary { background:var(--accent); color:#fff; box-shadow:0 6px 16px rgba(217,119,87,.32); }
    .btn-primary:hover { transform:translateY(-1px); }
    .btn-ghost { background:var(--surface); color:var(--ink); border-color:var(--hair); }
    .btn-ghost:hover { border-color:var(--accent); color:var(--accent-ink); }
    /* ── Hero feature card (latest post) ─────────────── */
    .hero-side { display:flex; flex-direction:column; gap:1.25rem; }
    .hero-illustration svg { width:100%; height:auto; display:block; filter:drop-shadow(0 14px 30px rgba(30,26,20,.08)); }
    .hero-illustration .flow { stroke:var(--accent); stroke-width:2.5; stroke-dasharray:3 17; animation:flowPulse 1.5s linear infinite; }
    @keyframes flowPulse { to { stroke-dashoffset:-40; } }
    .scroll-cue { position:absolute; left:50%; bottom:16px; transform:translateX(-50%); display:grid; place-items:center; width:42px; height:42px; border-radius:50%; border:1px solid var(--hair); background:var(--surface); color:var(--accent-ink); box-shadow:var(--shadow-sm); animation:bob 1.7s ease-in-out infinite; z-index:2; }
    .scroll-cue:hover { border-color:var(--accent); }
    .scroll-cue svg { width:20px; height:20px; }
    @keyframes bob { 0%,100%{ transform:translateX(-50%) translateY(0); } 50%{ transform:translateX(-50%) translateY(6px); } }
    /* ── Credibility strip ───────────────────────────── */
    .cred { border-bottom:1px solid var(--hair); background:var(--bg-tint); }
    .cred .wrap { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; padding-block:1.35rem; }
    .cred-item { display:flex; align-items:center; gap:.8rem; }
    .cred-item > svg { width:22px; height:22px; color:var(--accent-ink); flex:none; }
    .cred-item strong { display:block; font-family:var(--body); font-weight:600; font-size:.92rem; color:var(--ink); }
    .cred-item span { display:block; font-size:.82rem; color:var(--muted); line-height:1.4; margin-top:.1rem; }
    @media (max-width:760px){ .cred .wrap{ grid-template-columns:1fr; gap:1rem; } }
    .feature { display:block; background:var(--surface); border:1px solid var(--hair); border-radius:18px; padding:1.6rem 1.7rem; box-shadow:var(--shadow); text-decoration:none; color:var(--ink); transition:transform .16s ease, box-shadow .2s ease; }
    .feature:hover { transform:translateY(-3px); box-shadow:var(--shadow), 0 0 0 1px var(--accent); }
    .feature-eyebrow { display:inline-flex; align-items:center; gap:.4rem; font-family:var(--mono); font-size:.72rem; letter-spacing:.06em; text-transform:uppercase; color:var(--accent-ink); margin-bottom:.9rem; }
    .feature-eyebrow svg { width:14px; height:14px; }
    .feature h2 { font-family:var(--display); font-weight:700; font-size:1.5rem; line-height:1.25; letter-spacing:-0.01em; margin:0 0 .6rem; }
    .feature p { color:var(--muted); font-size:.98rem; line-height:1.55; margin:0 0 1.2rem; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }
    .feature-meta { display:flex; align-items:center; justify-content:space-between; gap:1rem; font-family:var(--mono); font-size:.74rem; color:var(--muted); border-top:1px solid var(--hair); padding-top:1rem; }
    .feature-go { display:inline-flex; align-items:center; gap:.35rem; color:var(--accent-ink); font-weight:500; }
    .feature-go svg { width:14px; height:14px; transition:transform .16s ease; }
    .feature:hover .feature-go svg { transform:translateX(3px); }
    @media (max-width:820px){ .hero .wrap{ grid-template-columns:1fr; } }

    /* ── Notes section head + controls ────────────────── */
    .notes { padding-block:clamp(1rem,3vw,2rem) 3rem; }
    .notes-head { display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:1.5rem; }
    .notes-head h2 { font-family:var(--display); font-weight:700; letter-spacing:-0.01em; font-size:1.6rem; margin:0; display:flex; align-items:center; gap:.6rem; }
    .count { font-family:var(--mono); font-size:.78rem; color:var(--accent-ink); background:var(--pill-bg); padding:.2rem .55rem; border-radius:999px; }
    .controls { display:flex; align-items:center; gap:.6rem; }
    .search { display:flex; align-items:center; gap:.5rem; background:var(--surface); border:1px solid var(--hair); border-radius:10px; padding:.5rem .7rem; min-width:200px; }
    .search:focus-within { border-color:var(--accent); }
    .search svg { width:16px; height:16px; color:var(--muted); flex:none; }
    .search input { border:0; outline:0; background:transparent; color:var(--ink); font:inherit; font-size:.92rem; width:100%; }
    .filter-wrap { position:relative; }
    .ctrl-btn { display:inline-flex; align-items:center; gap:.45rem; background:var(--surface); border:1px solid var(--hair); border-radius:10px; padding:.55rem .8rem; font:inherit; font-size:.9rem; color:var(--ink-soft); cursor:pointer; }
    .ctrl-btn:hover { border-color:var(--accent); color:var(--accent-ink); }
    .ctrl-btn svg { width:15px; height:15px; }
    .filter-menu { position:absolute; right:0; top:calc(100% + .4rem); background:var(--surface); border:1px solid var(--hair); border-radius:12px; box-shadow:var(--shadow); padding:.4rem; min-width:180px; z-index:20; display:none; }
    .filter-menu.open { display:block; }
    .filter-menu button { display:block; width:100%; text-align:left; background:none; border:0; font:inherit; font-size:.9rem; color:var(--ink-soft); padding:.5rem .65rem; border-radius:8px; cursor:pointer; }
    .filter-menu button:hover { background:var(--bg-tint); }
    .filter-menu button[aria-pressed="true"] { color:var(--accent-ink); background:var(--pill-bg); font-weight:600; }
    .viewtoggle { display:flex; border:1px solid var(--hair); border-radius:10px; overflow:hidden; }
    .viewtoggle button { display:grid; place-items:center; width:38px; height:38px; background:var(--surface); border:0; color:var(--muted); cursor:pointer; }
    .viewtoggle button svg { width:17px; height:17px; }
    .viewtoggle button[aria-pressed="true"] { background:var(--pill-bg); color:var(--accent-ink); }
    @media (max-width:600px){ .search{ min-width:0; flex:1; } .notes-head{ gap:.6rem; } }

    /* ── Cards (grid) ─────────────────────────────────── */
    .cards { display:grid; grid-template-columns:repeat(3,1fr); gap:1.1rem; }
    @media (max-width:900px){ .cards{ grid-template-columns:repeat(2,1fr); } }
    @media (max-width:600px){ .cards{ grid-template-columns:1fr; } }
    .card { background:var(--surface); border:1px solid var(--hair); border-radius:16px; box-shadow:var(--shadow-sm); overflow:hidden; transition:transform .14s ease, box-shadow .2s ease; }
    .card:hover { transform:translateY(-3px); box-shadow:var(--shadow); }
    .card a.cardlink { display:block; text-decoration:none; color:inherit; height:100%; }
    .card .top { display:flex; gap:1rem; padding:1.15rem 1.15rem 0; }
    .card .txt { flex:1; min-width:0; }
    .card .thumb { width:78px; height:78px; flex:none; border-radius:12px; overflow:hidden; background:var(--bg-tint); display:grid; place-items:center; }
    .card .thumb img { width:100%; height:100%; object-fit:cover; }
    .card .thumb.fallback::after { content:"</>"; font-family:var(--mono); color:var(--accent); font-size:1.1rem; }
    .pill-cat { font-family:var(--mono); font-size:.66rem; letter-spacing:.07em; text-transform:uppercase; color:var(--accent-ink); }
    .card h3 { font-family:var(--display); font-weight:700; font-size:1.05rem; line-height:1.3; letter-spacing:-0.01em; margin:.45rem 0 0; }
    .card .meta { display:flex; align-items:center; gap:.8rem; padding:1rem 1.15rem 1.15rem; font-family:var(--mono); font-size:.74rem; color:var(--muted); }
    .card .meta .mi { display:inline-flex; align-items:center; gap:.3rem; }
    .card .meta svg { width:13px; height:13px; }

    /* ── List view ────────────────────────────────────── */
    .cards.list { display:block; border-top:1px solid var(--hair); }
    .cards.list .card { border:0; border-bottom:1px solid var(--hair); border-radius:0; box-shadow:none; transform:none; background:transparent; }
    .cards.list .card:hover { box-shadow:none; background:var(--bg-tint); }
    .cards.list a.cardlink { display:grid; grid-template-columns:64px 1fr auto auto; gap:1.1rem; align-items:center; padding:1.1rem .6rem; }
    .cards.list .thumb { width:64px; height:64px; }
    .cards.list .top { display:contents; padding:0; }
    .cards.list .txt { min-width:0; }
    .cards.list h3 { margin:.25rem 0 .25rem; font-size:1.05rem; }
    .cards.list .dek { color:var(--muted); font-size:.9rem; line-height:1.5; margin:0; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
    .cards.list .meta { padding:0; white-space:nowrap; }
    .cards.list .chev { color:var(--muted); display:grid; place-items:center; }
    .cards.list .chev svg { width:18px; height:18px; }
    .card .dek { display:none; }
    .cards:not(.list) .chev { display:none; }
    @media (max-width:700px){ .cards.list a.cardlink{ grid-template-columns:56px 1fr; } .cards.list .meta, .cards.list .chev{ display:none; } }

    .loadmore-row { display:flex; justify-content:center; margin-top:1.75rem; }
    .loadmore { display:inline-flex; align-items:center; gap:.5rem; background:var(--surface); border:1px solid var(--hair); border-radius:10px; padding:.65rem 1.1rem; font:inherit; font-size:.9rem; color:var(--ink-soft); cursor:pointer; }
    .loadmore:hover { border-color:var(--accent); color:var(--accent-ink); }
    .loadmore svg { width:15px; height:15px; }
    .empty { color:var(--muted); font-family:var(--mono); font-size:.9rem; padding:2rem 0; text-align:center; }

    /* ── Article ──────────────────────────────────────── */
    .article { padding:clamp(2.5rem,7vw,4rem) 0 5rem; }
    .about-head { display:flex; align-items:center; gap:1.25rem; margin-bottom:1.5rem; }
    .about-head h1 { margin:0; }
    .about-sub { margin:.35rem 0 0; color:var(--muted); font-family:var(--mono); font-size:.8rem; letter-spacing:.03em; text-transform:uppercase; }
    .avatar { width:96px; height:96px; border-radius:50%; object-fit:cover; flex:none; border:1px solid var(--hair); box-shadow:var(--shadow-sm); }
    @media (max-width:480px){ .about-head{ gap:1rem; } .avatar{ width:72px; height:72px; } }
    .about-grid { display:grid; grid-template-columns:minmax(0,1fr) 300px; gap:clamp(2rem,5vw,4rem); align-items:start; }
    .about-side { display:flex; flex-direction:column; gap:1rem; position:sticky; top:84px; }
    .side-card { background:var(--surface); border:1px solid var(--hair); border-radius:14px; padding:1.25rem 1.35rem; box-shadow:var(--shadow-sm); }
    .side-card h3 { font-family:var(--mono); font-weight:500; font-size:.72rem; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); margin:0 0 .95rem; }
    .side-card .chips { list-style:none; display:flex; flex-wrap:wrap; gap:.45rem; margin:0; padding:0; }
    .side-card .chips li { font-family:var(--body); font-size:.8rem; color:var(--ink-soft); background:var(--bg-tint); border:1px solid var(--hair); border-radius:999px; padding:.3rem .7rem; }
    .side-links { list-style:none; margin:0; padding:0; }
    .side-links a { display:flex; align-items:center; gap:.65rem; padding:.5rem 0; color:var(--ink-soft); text-decoration:none; font-family:var(--body); font-size:.92rem; }
    .side-links a:hover { color:var(--accent-ink); }
    .side-links svg { width:16px; height:16px; flex:none; color:var(--muted); }
    .side-links a:hover svg { color:var(--accent-ink); }
    @media (max-width:820px){ .about-grid{ grid-template-columns:1fr; } .about-side{ position:static; } }
    .article .back { display:inline-block; margin-bottom:1.6rem; font-family:var(--mono); font-size:.78rem; color:var(--accent-ink); text-decoration:none; }
    .article .back:hover { text-decoration:underline; }
    .article .post-meta { font-family:var(--mono); font-size:.76rem; color:var(--muted); text-transform:uppercase; letter-spacing:.05em; margin-bottom:.6rem; }
    .article h1 { font-family:var(--serif); font-weight:700; font-size:clamp(1.9rem,5vw,2.8rem); line-height:1.15; letter-spacing:-0.02em; margin:0 0 2rem; }
    .prose { max-width:52rem; font-family:var(--serif); font-size:1.1rem; line-height:1.7; }
    .prose > * { margin-block:1.3rem; }
    .prose h2 { font-family:var(--serif); font-weight:700; font-size:1.55rem; margin-top:2.75rem; line-height:1.25; letter-spacing:-0.01em; }
    .prose h3 { font-family:var(--serif); font-weight:600; font-size:1.25rem; margin-top:2rem; }
    .prose a { color:var(--accent-ink); text-underline-offset:2px; }
    .prose img { display:block; max-width:100%; height:auto; border-radius:12px; border:1px solid var(--hair); margin-block:2rem; }
    .prose img[src*="/hero"] { border:none; }
    .prose pre { background:var(--code-bg); border:1px solid var(--hair); padding:1.1rem 1.25rem; border-radius:12px; overflow-x:auto; font-size:.86rem; line-height:1.55; }
    .prose code { font-family:var(--mono); font-size:.88em; }
    .prose :not(pre) > code { background:var(--code-bg); padding:.12em .38em; border-radius:5px; }
    .prose blockquote { margin-inline:0; padding-left:1.1rem; border-left:3px solid var(--accent); color:var(--muted); }

    footer { border-top:1px solid var(--hair); margin-top:2rem; }
    footer .wrap { padding-block:2rem 3rem; display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap; font-size:.88rem; color:var(--muted); }
    footer a { color:var(--accent-ink); text-decoration:none; }
    .social { display:flex; gap:.4rem; }
    .social a { display:grid; place-items:center; width:34px; height:34px; border-radius:8px; color:var(--muted); }
    .social a:hover { color:var(--accent-ink); background:var(--bg-tint); }
    .social svg { width:17px; height:17px; }

    @media (prefers-reduced-motion:reduce){ *,html{ transition:none !important; animation:none !important; scroll-behavior:auto; } }
  </style>
</head>
<body>
  <nav class="nav">
    <div class="wrap">
      <a class="brand" href="/">
        <svg class="mark" viewBox="0 0 40 40" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
          <rect width="40" height="40" rx="10" fill="var(--accent)"/>
          <g fill="none" stroke="#fff" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M27 13.4a9.3 9.3 0 1 0 0 13.2"/>
            <path d="M18.8 13.8v12.4"/>
            <path d="M18.8 20l7-6.2M18.8 20l7 6.2"/>
          </g>
        </svg>
        {{ site.title }}
      </a>
      <div class="nav-links">
        <a href="/" {% if page.url == "/" %}aria-current="page"{% endif %}>Home</a>
        <a href="/#notes">Blog</a>
        <a href="/about/">About</a>
        <button class="icon-btn" id="theme-toggle" aria-label="Toggle theme">
          <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.4 1.4M17.6 17.6L19 19M19 5l-1.4 1.4M6.4 17.6L5 19"/></svg>
          <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12.8A9 9 0 1111.2 3a7 7 0 009.8 9.8z"/></svg>
        </button>
        <a class="rss icon-btn" href="/feed.xml" aria-label="RSS feed">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 11a9 9 0 019 9M4 4a16 16 0 0116 16"/><circle cx="5" cy="19" r="1.4" fill="currentColor" stroke="none"/></svg>
        </a>
      </div>
    </div>
  </nav>

  {{ content | safe }}

  <footer>
    <div class="wrap">
      <span>© 2026 {{ site.title }} · Built from markdown, <a href="/feed.xml">syndicated via RSS</a></span>
      <span class="social">
