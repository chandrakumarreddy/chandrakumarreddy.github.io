---
layout: base.njk
permalink: "/{{ page.fileSlug }}/index.html"
---
<main class="article">
  <div class="wrap">
    <a class="back" href="/">← all posts</a>
    <p class="post-meta">
      {{ page.date | readableDate }}{% if prNumber %} · PR #{{ prNumber }}{% endif %}
    </p>
    <h1>{{ title }}</h1>
    {%- if keywords and keywords.length %}
    <ul class="post-tags" aria-label="Tags">
      {%- for kw in keywords %}
      <li>{{ kw }}</li>
      {%- endfor %}
    </ul>
    {%- endif %}
    <div class="prose">
      {{ content | safe }}
    </div>
  </div>
</main>
