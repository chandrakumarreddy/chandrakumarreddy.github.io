---
layout: base.njk
permalink: "/index.html"
---
<header class="hero">
  <div class="wrap">
    <div>
      <h1>Engineering notes on <span class="grad">full-stack, ML, infrastructure,</span> and system design.</h1>
      <p class="lede">{{ site.description }}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/#notes">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 20h9M16.5 3.5a2.1 2.1 0 013 3L7 19l-4 1 1-4z"/></svg>
          Read Notes
        </a>
        <a class="btn btn-ghost" href="/feed.xml">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 11a9 9 0 019 9M4 4a16 16 0 0116 16"/><circle cx="5" cy="19" r="1.4" fill="currentColor" stroke="none"/></svg>
          Subscribe via RSS
        </a>
      </div>
    </div>
    <div class="hero-art" aria-hidden="true">
      <svg viewBox="0 0 420 360" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="g1" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#6366F1"/><stop offset="1" stop-color="#8B5CF6"/></linearGradient>
          <radialGradient id="glow" cx="55%" cy="40%" r="60%"><stop offset="0" stop-color="#8B5CF6" stop-opacity="0.22"/><stop offset="1" stop-color="#8B5CF6" stop-opacity="0"/></radialGradient>
          <filter id="soft" x="-30%" y="-30%" width="160%" height="160%"><feDropShadow dx="0" dy="18" stdDeviation="22" flood-color="#6357C9" flood-opacity="0.18"/></filter>
        </defs>
        <rect width="420" height="360" fill="url(#glow)"/>
        <g filter="url(#soft)"><rect x="118" y="64" width="200" height="200" rx="34" fill="var(--surface)" stroke="var(--hair)"/></g>
        <path d="M188 139l-22 25 22 25" fill="none" stroke="url(#g1)" stroke-width="11" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M248 139l22 25-22 25" fill="none" stroke="url(#g1)" stroke-width="11" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M224 132l-12 64" stroke="url(#g1)" stroke-width="11" stroke-linecap="round"/>
        <g filter="url(#soft)"><rect x="150" y="272" width="92" height="20" rx="5" fill="url(#g1)"/><rect x="158" y="292" width="92" height="18" rx="5" fill="var(--ink-soft)" opacity="0.85"/></g>
        <circle cx="332" cy="246" r="26" fill="none" stroke="var(--hair)" stroke-width="10"/><path d="M358 240h10a10 10 0 010 20h-7" fill="none" stroke="var(--hair)" stroke-width="8"/>
      </svg>
    </div>
  </div>
</header>

<main>
  <section class="notes wrap" id="notes">
    <div class="notes-head">
      <h2>All Notes <span class="count" id="note-count">0</span></h2>
      <div class="controls">
        <label class="search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
          <input type="search" id="note-search" placeholder="Search notes…" aria-label="Search notes">
        </label>
        <div class="filter-wrap">
          <button class="ctrl-btn" id="filter-btn" aria-haspopup="true" aria-expanded="false">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 5h18M6 12h12M10 19h4"/></svg>
            <span id="filter-label">Filter</span>
          </button>
          <div class="filter-menu" id="filter-menu" role="menu"></div>
        </div>
        <div class="viewtoggle" role="group" aria-label="View">
          <button id="view-grid" aria-pressed="true" aria-label="Grid view"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg></button>
          <button id="view-list" aria-pressed="false" aria-label="List view"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg></button>
        </div>
      </div>
    </div>

    <div class="cards" id="cards"></div>
    <div class="loadmore-row"><button class="loadmore" id="loadmore" hidden>Load more <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M19 12l-7 7-7-7"/></svg></button></div>
    <p class="empty" id="empty" hidden>No notes match your search.</p>
  </section>

  <script id="posts-data" type="application/json">{{ collections.posts | postsJson | safe }}</script>
  <script>
  (function () {
    var DATA = JSON.parse(document.getElementById("posts-data").textContent || "[]");
    var STEP = 6;
    var state = { q: "", cat: null, view: "grid", shown: STEP };
    try { var v = localStorage.getItem("notes-view"); if (v) state.view = v; } catch (e) {}

    var $cards = document.getElementById("cards");
    var $count = document.getElementById("note-count");
    var $empty = document.getElementById("empty");
    var $more  = document.getElementById("loadmore");
    var $search = document.getElementById("note-search");
    var $gridBtn = document.getElementById("view-grid");
    var $listBtn = document.getElementById("view-list");
    var $filterBtn = document.getElementById("filter-btn");
    var $filterMenu = document.getElementById("filter-menu");
    var $filterLabel = document.getElementById("filter-label");

    function esc(s){ return String(s).replace(/[&<>"]/g, function(c){ return {"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;"}[c]; }); }

    // Build filter menu from unique categories
    var cats = []; DATA.forEach(function(p){ (p.categories||[]).forEach(function(c){ if(cats.indexOf(c)<0) cats.push(c); }); });
    var menuHtml = '<button role="menuitem" data-cat="" aria-pressed="true">All categories</button>';
    cats.forEach(function(c){ menuHtml += '<button role="menuitem" data-cat="'+esc(c)+'">'+esc(c)+'</button>'; });
    $filterMenu.innerHTML = menuHtml;

    function filtered(){
      var q = state.q.toLowerCase();
      return DATA.filter(function(p){
        var inCat = !state.cat || (p.categories||[]).indexOf(state.cat) >= 0;
        var hay = (p.title+" "+p.description+" "+(p.categories||[]).join(" ")).toLowerCase();
        return inCat && (!q || hay.indexOf(q) >= 0);
      });
    }

    function metaHtml(p){
      return '<span class="mi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>'+esc(p.date)+'</span>'+
             '<span class="mi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>'+p.minutes+' min read</span>';
    }
    function thumbHtml(p){
      return '<span class="thumb"><img src="'+esc(p.thumb)+'" alt="" loading="lazy" onerror="this.parentNode.classList.add(\'fallback\');this.remove()"></span>';
    }
    function cardHtml(p){
      var cat = (p.categories||[]).join(" · ");
      return '<article class="card"><a class="cardlink" href="'+esc(p.url)+'">'+
        '<div class="top">'+thumbHtml(p)+
          '<div class="txt">'+(cat?'<span class="pill-cat">'+esc(cat)+'</span>':'')+
            '<h3>'+esc(p.title)+'</h3>'+
            '<p class="dek">'+esc(p.description)+'</p>'+
          '</div></div>'+
        '<div class="meta">'+metaHtml(p)+'</div>'+
        '<span class="chev"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 6l6 6-6 6"/></svg></span>'+
      '</a></article>';
    }

    function render(){
      var list = filtered();
      $count.textContent = list.length;
      $cards.className = "cards" + (state.view === "list" ? " list" : "");
      $gridBtn.setAttribute("aria-pressed", state.view === "grid");
      $listBtn.setAttribute("aria-pressed", state.view === "list");
      var slice = list.slice(0, state.shown);
      $cards.innerHTML = slice.map(cardHtml).join("");
      $empty.hidden = list.length !== 0;
      $more.hidden = list.length <= state.shown;
    }

    $search.addEventListener("input", function(){ state.q = this.value; state.shown = STEP; render(); });
    $more.addEventListener("click", function(){ state.shown += STEP; render(); });
    $gridBtn.addEventListener("click", function(){ state.view = "grid"; persistView(); render(); });
    $listBtn.addEventListener("click", function(){ state.view = "list"; persistView(); render(); });
    function persistView(){ try { localStorage.setItem("notes-view", state.view); } catch (e) {} }

    $filterBtn.addEventListener("click", function(e){ e.stopPropagation(); var open=$filterMenu.classList.toggle("open"); $filterBtn.setAttribute("aria-expanded", open); });
    document.addEventListener("click", function(){ $filterMenu.classList.remove("open"); $filterBtn.setAttribute("aria-expanded","false"); });
    $filterMenu.addEventListener("click", function(e){
      var b = e.target.closest("button"); if(!b) return;
      state.cat = b.getAttribute("data-cat") || null; state.shown = STEP;
      Array.prototype.forEach.call($filterMenu.children, function(x){ x.setAttribute("aria-pressed", x===b); });
      $filterLabel.textContent = state.cat || "Filter";
      render();
    });

    render();
  })();
  </script>
</main>
