---
permalink: "/{{ page.fileSlug }}/index.html"
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} — {{ site.title }}</title>
  <link rel="canonical" href="{{ site.url }}/{{ page.fileSlug }}/">
  <link rel="alternate" type="application/atom+xml" href="{{ site.url }}/feed.xml">
  <style>
    body { max-width: 740px; margin: 2rem auto; padding: 0 1rem;
           font: 16px/1.6 -apple-system, "Segoe UI", Roboto, sans-serif; color: #1a1a1a; }
    img { max-width: 100%; height: auto; }
    pre { background: #f5f5f5; padding: 1rem; overflow-x: auto; border-radius: 6px; }
    code { font-family: ui-monospace, "SF Mono", Menlo, monospace; }
  </style>
</head>
<body>
  <article>
    <h1>{{ title }}</h1>
    {{ content | safe }}
  </article>
</body>
</html>
